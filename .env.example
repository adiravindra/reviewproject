REVIEWINSIGHT_DB_PATH=data/reviewinsight.db
# Model summaries are enabled by default. Set to 0 to use only the rule-based fallback.
REVIEWINSIGHT_ENABLE_MODEL_SUMMARY=1
# Model sentiment is enabled by default. Set to 0 to use only the rule-based fallback.
REVIEWINSIGHT_ENABLE_MODEL_SENTIMENT=1
# Model downloads are allowed by default. Set to 1 to use only locally cached files.
REVIEWINSIGHT_MODEL_LOCAL_ONLY=0
